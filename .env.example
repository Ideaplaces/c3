# C3 Configuration
# Copy this to .env.local and fill in your values

# Authentication
JWT_SECRET=               # Generate with: openssl rand -base64 48
CCC_ALLOWED_EMAILS=       # Comma-separated list of allowed emails
C3_LOGIN_PASSWORD=        # Optional: password for /api/auth/password endpoint

# Magic Link (optional, requires Resend account)
RESEND_API_KEY=           # From https://resend.com
C3_FROM_EMAIL=C3 <noreply@yourdomain.com>

# Server
PORT=8347
NEXT_PUBLIC_BASE_URL=http://localhost:8347
C3_BASE_URL=http://localhost:8347

# Project directories to scan
CCC_PROJECT_DIRS=~/projects

# Webhook secret for Discord/Slack triggers
CCC_WEBHOOK_SECRET=       # Generate with: openssl rand -hex 32

# Discord bot (optional)
DISCORD_BOT_TOKEN=

# Slack poller (optional)
SLACK_BOT_TOKEN=
